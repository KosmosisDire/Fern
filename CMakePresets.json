{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "windows-debug",
            "displayName": "Windows - Debug",
            "description": "Debug build with LLVM",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/Debug",
            "condition": {
                "type": "notEquals",
                "lhs": "$env{CI}",
                "rhs": "true"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE"
            }
        },
         {
            "name": "windows-debug-no-llvm",
            "displayName": "Windows - Debug (No LLVM)",
            "description": "Debug build without LLVM backend (VM only).",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/Debug-NoLLVM",
            "condition": {
                "type": "notEquals",
                "lhs": "$env{CI}",
                "rhs": "true"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE",
                "FERN_BUILD_LLVM": "OFF"
            }
        },
        {
            "name": "windows-release",
            "displayName": "Windows - Release",
            "description": "Release build with LLVM",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/Release",
            "condition": {
                "type": "notEquals",
                "lhs": "$env{CI}",
                "rhs": "true"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Linux - Debug",
            "description": "Debug build for Linux using system packages.",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux - Release",
            "description": "Release build for Linux using system packages.",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE"
            }
        },
        {
            "name": "github-actions-linux",
            "displayName": "GitHub Actions - Linux",
            "description": "Release build for GitHub Actions Linux runners.",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "condition": {
                "type": "equals",
                "lhs": "$env{CI}",
                "rhs": "true"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE"
            }
        },
        {
            "name": "github-actions-windows",
            "displayName": "GitHub Actions - Windows",
            "description": "Release build for GitHub Actions Windows runners.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/Release",
            "condition": {
                "type": "equals",
                "lhs": "$env{CI}",
                "rhs": "true"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "TRUE"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug-build",
            "displayName": "Build (Debug)",
            "configurePreset": "windows-debug",
            "description": "Build the Debug configuration."
        },
        {
            "name": "release-build",
            "displayName": "Build (Release)",
            "configurePreset": "windows-release",
            "description": "Build the Release configuration."
        },
        {
            "name": "linux-debug-build",
            "displayName": "Linux Build (Debug)",
            "configurePreset": "linux-debug",
            "description": "Build the Debug configuration on Linux."
        },
        {
            "name": "linux-release-build",
            "displayName": "Linux Build (Release)",
            "configurePreset": "linux-release",
            "description": "Build the Release configuration on Linux."
        }
    ],
    "testPresets": [
        {
            "name": "debug-test",
            "displayName": "Test (Debug)",
            "configurePreset": "windows-debug",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error"
            }
        },
        {
            "name": "release-test",
            "displayName": "Test (Release)",
            "configurePreset": "windows-release",
            "output": {
                "outputOnFailure": true
            },
            "execution": {
                "noTestsAction": "error"
            }
        }
    ]
}
