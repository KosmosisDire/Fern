{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 18,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-debug",
      "displayName": "Windows - Debug",
      "description": "Debug build for Windows with LLVM and libffi",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-release",
      "displayName": "Windows - Release",
      "description": "Release build for Windows with LLVM and libffi",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-debug",
      "displayName": "Linux - Debug",
      "description": "Debug build for Linux with LLVM and libffi",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_COMPILER": "clang-19",
        "CMAKE_CXX_COMPILER": "clang++-19"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux - Release",
      "description": "Release build for Linux with LLVM and libffi",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_COMPILER": "clang-19",
        "CMAKE_CXX_COMPILER": "clang++-19"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "linux-fuzz",
      "displayName": "Linux - Fuzz",
      "description": "libFuzzer harness with ASan, frontend only (no LLVM, libffi, CLI, or LSP)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/fuzz",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_COMPILER": "clang-19",
        "CMAKE_CXX_COMPILER": "clang++-19",
        "FERN_BUILD_FUZZER": "ON",
        "FERN_BUILD_LLVM": "OFF",
        "FERN_BUILD_LIBFFI": "OFF",
        "FERN_BUILD_CLI": "OFF",
        "FERN_BUILD_LSP": "OFF"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug-build",
      "displayName": "Build (Windows Debug)",
      "configurePreset": "windows-debug"
    },
    {
      "name": "windows-release-build",
      "displayName": "Build (Windows Release)",
      "configurePreset": "windows-release"
    },
    {
      "name": "linux-debug-build",
      "displayName": "Build (Linux Debug)",
      "configurePreset": "linux-debug"
    },
    {
      "name": "linux-release-build",
      "displayName": "Build (Linux Release)",
      "configurePreset": "linux-release"
    },
    {
      "name": "linux-fuzz-build",
      "displayName": "Build (Linux Fuzz)",
      "configurePreset": "linux-fuzz",
      "targets": ["fernfuzz"]
    }
  ],
  "testPresets": [
    {
      "name": "windows-debug-test",
      "displayName": "Test (Windows Debug)",
      "configurePreset": "windows-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-release-test",
      "displayName": "Test (Windows Release)",
      "configurePreset": "windows-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-debug-test",
      "displayName": "Test (Linux Debug)",
      "configurePreset": "linux-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-release-test",
      "displayName": "Test (Linux Release)",
      "configurePreset": "linux-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
