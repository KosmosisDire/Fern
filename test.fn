


ref type Token
{
    string value
    bool isNumber
    bool isOperator

    new(string v)
    {
        value = v
    }

    fn ToFloat() -> float
    {
        if (!isNumber)
        {
            Print("Error: Token is not a number.")
            return 0.0
        }
        PrintLn("Converting token to float: " .Concat(value))
        PrintLn(FloatToString(StringToFloat(value)))
        return StringToFloat(value)
    }
}

ref type Expression
{
    float left
    Token operator
    Expression right

    new()
    {
    }

    fn ToString() -> string
    {
        if (right == null || operator == null || operator.value == null)
        {
            return "Left: ".Concat(FloatToString(left))
        }
        PrintLn("Expression ToString called")

        var result = "Left: ".Concat(FloatToString(left)).Concat(", ")
                        .Concat("Operator: ").Concat(operator.value).Concat(", ")
                        .Concat("Right: \n{ ").Concat(right.ToString()).Concat(" }\n")

        return result
    }
}

type TokenList
{
    Token* tokens
    int count
    int capacity
    int tokenSize

    new()
    {
        tokenSize = 8
        capacity = 10
        tokens = (Token*)malloc(capacity * tokenSize)
        count = 0
    }

    fn Grow
    {
        capacity *= 2
        Token* newTokens = (Token*)malloc(capacity * tokenSize)
        memcpy(newTokens, tokens, count * tokenSize)
        free(tokens)
        tokens = newTokens
    }

    fn Add(Token t)
    {
        if (count >= capacity)
        {
            Grow()
        }
        tokens[count] = t
        count += 1
    }

    fn Get(int index)
    {
        return tokens[index]
    }

    fn Count
    {
        return count
    }

    fn Free
    {
        free(tokens)
    }

    fn ToString() -> string
    {
        var result = "["
        for (int i = 0; i < count; i += 1)
        {
            result = result.Concat(tokens[i].value)
            if (i < count - 1)
            {
                result = result.Concat(", ")
            }
        }
        result = result.Concat("]")
        return result
    }
}

fn IsDigit(char ch) -> bool
{
    return ch >= '0' && ch <= '9'
}

fn Main
{
    var input = "34 * 4 + 2"
    var tokenList = new TokenList()

    for (i32 i = 0; i < input.Length(); i += 1)
    {
        var ch = input.data[i]
        var next = '\0'
        if (i + 1 < input.Length())
        {
            next = input.data[i + 1]
        }

        if (ch == ' ')
        {
            continue
        }
        
        if (IsDigit(ch))
        {
            var numStr = CharToString(ch)
            while (IsDigit(next) || next == '.')
            {
                i += 1
                ch = next
                numStr = numStr.Concat(CharToString(ch))
                if (i + 1 < input.Length())
                {
                    next = input.data[i + 1]
                }
                else
                {
                    break
                }
            }
            var numberToken = new Token(numStr)
            numberToken.isNumber = true
            tokenList.Add(numberToken)
            continue
        }
        
        var token = new Token(CharToString(ch))
        tokenList.Add(token)
    }

    PrintLn(tokenList.ToString())

    var root = new Expression()
    var expr = root
    var tokenIter = 0
    while (tokenIter < tokenList.Count())
    {
        var currentToken = tokenList.Get(tokenIter)
        if (currentToken.isNumber)
        {
            if (expr.operator == null)
            {
                -- No operator yet - this is the left side
                expr.left = currentToken.ToFloat()
            }
            else
            {
                -- Already have operator - build right subtree
                expr.right = new Expression()
                expr = expr.right
                expr.left = currentToken.ToFloat()
            }
        }
        else
        {
            expr.operator = currentToken
        }

        tokenIter += 1
    }

    PrintLn("")
    PrintLn(root.ToString())

    tokenList.Free()
    return 0.0
}