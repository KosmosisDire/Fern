type Player
{
    i32 health
    f32 healthModifier

    fn GetHealth
    {
        return health * healthModifier
    }

    new(i32 h, f32 mod)
    {
        health = h
        healthModifier = mod
    }
}


fn Main
{
    var player = new Player(100, 1 + (3.1 / 2))
    f32 total = player.GetHealth()
    return total
}
