

type Vector2
{
    x: f32
    y: f32

    init(x: f32, y: f32)
    {
        this.x = x
        this.y = y
    }

    init{}


    static fn v(x: f32) -> Vector2
    {
        return Vector2(x, x)
    }

    literal v(value: f32) -> Vector2
    {
        return Vector2(value, value)
    }
}


type Program
{
    fn Main
    {
        var v1 = Vector2.v(1.0)
        var v2 = 1.0v
    }
}

