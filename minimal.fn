
namespace Math
{
    type Vector2
    {
        x: f32
        y: f32

        init(x: f32, y: f32)
        {
            this.x = x
            this.y = y
        }

        init{}
    }
}

type Program
{
    fn Main
    {
        var v1 = Math.Vector2(1.0, 2.0)
        var v2 = Math.Vector2 { x: 3.0, y: 4.0 }
        var v3 = Math.Vector2(1.0, 2.0) { x: 3.0, y: 4.0 }
    }
}