extern fn Fern_Clay_SizingType_Grow() -> i32
extern fn Fern_Clay_SizingType_Percent() -> i32
extern fn Fern_Clay_SizingType_Fixed() -> i32

-- ============================================================================
-- Fern Types
-- ============================================================================

-- RGBA Color (0-255 range)
type Color
{
    f32 r
    f32 g
    f32 b
    f32 a

    new(f32 red, f32 green, f32 blue, f32 alpha)
    {
        r = red
        g = green
        b = blue
        a = alpha
    
}
}

-- 2D Rectangle
type Rect
{
    f32 x
    f32 y
    f32 width
    f32 height

    new(f32 px, f32 py, f32 w, f32 h)
    {
        x = px
        y = py
        width = w
        height = h
    
}
}

-- Corner radius for rounded rectangles
type Corners
{
    f32 topLeft
    f32 topRight
    f32 bottomLeft
    f32 bottomRight

    new(f32 tl, f32 tr, f32 bl, f32 br)
    {
        topLeft = tl
        topRight = tr
        bottomLeft = bl
        bottomRight = br
    
}
}

-- Padding for elements
type Padding
{
    u16 left
    u16 right
    u16 top
    u16 bottom

    new(u16 l, u16 r, u16 t, u16 b)
    {
        left = l
        right = r
        top = t
        bottom = b
    
}
}

-- Sizing configuration
type Sizing
{
    f32 minWidth
    f32 maxWidth
    i32 widthType
    f32 minHeight
    f32 maxHeight
    i32 heightType

    new()
    {
        minWidth = 0.0
        maxWidth = 0.0
        widthType = 0  -- FIT
        minHeight = 0.0
        maxHeight = 0.0
        heightType = 0  -- FIT
    
}
}

-- Element layout configuration
type Layout
{
    Sizing sizing
    Padding padding
    u16 childGap
    i32 direction  -- 0 = LEFT_TO_RIGHT, 1 = TOP_TO_BOTTOM
    i32 alignX     -- 0 = LEFT, 1 = CENTER, 2 = RIGHT
    i32 alignY     -- 0 = TOP, 1 = CENTER, 2 = BOTTOM

    new()
    {
        sizing = new Sizing()
        padding = new Padding(0, 0, 0, 0)
        childGap = 0
        direction = 0
        alignX = 0
        alignY = 0
    
}
}

