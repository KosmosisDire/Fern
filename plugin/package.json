{
  "name": "fern-language",
  "displayName": "Fern Language Support",
  "description": "Language support for the Fern programming language",
  "version": "0.1.0",
  "publisher": "fern-lang",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:fern"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "fern",
        "aliases": ["Fern", "fern"],
        "extensions": [".fern", ".fn"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/fern-icon.svg",
          "dark": "./icons/fern-icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "fern",
        "scopeName": "source.fern",
        "path": "./syntaxes/fern.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Fern",
      "properties": {
        "fern.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Fern LSP server executable (FernLSP.exe). Leave empty to auto-detect."
        },
        "fern.includes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional files to include when compiling. Supports wildcards (e.g., 'runtime/*.fn', 'lib/utils.fn'). Paths are relative to workspace root."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.0"
  }
}