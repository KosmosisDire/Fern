{
    "name": "fern-language",
    "displayName": "Fern Language Support",
    "description": "Language support for the Fern programming language",
    "version": "0.1.0",
    "publisher": "fern-lang",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": ["Programming Languages"],
    "activationEvents": [
        "onLanguage:fern"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "fern.toggleLanguageServer",
                "title": "Fern: Toggle Language Server"
            }
        ],
        "languages": [
            {
                "id": "fern",
                "aliases": ["Fern", "fern"],
                "extensions": [".fern", ".fn"],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "fern",
                "scopeName": "source.fern",
                "path": "./syntaxes/fern.tmLanguage.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Fern",
            "properties": {
                "fern.lspPath": {
                    "type": "string",
                    "default": "",
                    "description": "Path to the Fern LSP server executable."
                },
                "fern.includes": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "description": "Files to always include when compiling, relative to workspace root (e.g. \"core.fn\")."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "build": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.10.0",
        "@types/vscode": "^1.74.0",
        "typescript": "^5.3.0"
    }
}
