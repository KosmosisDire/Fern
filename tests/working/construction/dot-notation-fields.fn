---
Description: Initializer using dot-notation field paths
Expected: 1
---

type Vector2
{
    x: f32
    y: f32
    init{}
}

type Rect
{
    pos: Vector2
    size: Vector2
    init{}
}

type Program
{
    fn Main -> i32
    {
        var r = Rect
        {
            pos.x: 1.0,
            pos.y: 2.0,
            size.x: 10.0,
            size.y: 20.0
        }
        return (i32)r.pos.x
    }
}
