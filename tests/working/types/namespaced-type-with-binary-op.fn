---
Description: Namespace-qualified type used with constructor, initializer, and operator
Expected: 7
---

namespace Math
{
    type Vector2
    {
        x: f32
        y: f32

        init(x: f32, y: f32)
        {
            this.x = x
            this.y = y
        }

        init{}

        op +(left: Vector2, right: Vector2) -> Vector2
        {
            return Vector2(left.x + right.x, left.y + right.y)
        }
    }
}

type Program
{
    static fn Main -> i32
    {
        var v1 = Math.Vector2(1.0, 2.0)
        var v2 = Math.Vector2 { x: 3.0, y: 4.0 }
        var v3 = v1 + v2
        return (i32)v3.x
    }
}
