---
Description: Strings used in if condition and while loop
Expected: 5
---

type Program
{
    static fn Main -> i32
    {
        var name = "World"
        var len = 0
        var i = 0
        while i < name.length
        {
            len += 1
            i += 1
        }
        if name == "World"
        {
            return len
        }
        return 0
    }
}
