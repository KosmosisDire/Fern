---
Description: Triple-quoted multiline string with deindentation
Expected: 3
---

type Program
{
    static fn Main -> i32
    {
        var s = """
            line one
            line two
            line three
        """
        var i = 0
        var lines = 1
        while i < s.length
        {
            if s[i] == '\n'
            {
                lines += 1
            }
            i += 1
        }
        return lines - 1
    }
}
