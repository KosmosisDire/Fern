---
Description: User-defined explicit cast between generic types
Expected: 42
---

type Box<T>
{
    value: T
    init(value: T)
    {
        this.value = value
    }
    init{}
}

type Container<T>
{
    value: T
    init(value: T)
    {
        this.value = value
    }
    init{}

    explicit cast(from: Box<T>) -> Container<T>
    {
        return Container<T>(from.value)
    }
}

type Program
{
    static fn Main -> i32
    {
        var intBox = Box<i32>(42)
        var c = (Container<i32>)intBox
        return c.value
    }
}
