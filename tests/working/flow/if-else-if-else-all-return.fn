---
Description: All branches of if/else if/else return
Expected: 2
---

type Program
{
    fn Main -> i32
    {
        var a = false
        var b = true
        if a
        {
            return 1
        }
        else if b
        {
            return 2
        }
        else
        {
            return 3
        }
    }
}
