---
Description: Generic type with two type parameters
Expected: 1
---

type Pair<A, B>
{
    first: A
    second: B

    init(first: A, second: B)
    {
        this.first = first
        this.second = second
    }

    fn First() -> A
    {
        return first
    }
}

type Program
{
    fn Main -> i32
    {
        var p = Pair<i32, f32>(1, 2.0)
        return p.First()
    }
}
