---
Description: Generic instantiated with another generic type as its argument
Expected: 42
---

type Box<T>
{
    value: T

    init(value: T)
    {
        this.value = value
    }

    fn Get() -> T
    {
        return value
    }
}

type Program
{
    fn Main -> i32
    {
        var bb = Box<Box<i32>>(Box<i32>(42))
        return bb.Get().Get()
    }
}
