---
Description: Core.Array iterated with a while loop
Expected: 60
---

type Program
{
    static fn Main -> i32
    {
        var arr = Core.Array<i32>(3)
        arr[0] = 10
        arr[1] = 20
        arr[2] = 30
        var total = 0
        var i = 0
        while i < arr.Length()
        {
            total = total + arr[i]
            i = i + 1
        }
        return total
    }
}
