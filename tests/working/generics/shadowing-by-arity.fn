---
Description: Same type name shadowed by arity
Expected: 11
---

type Tag
{
    id: i32

    init(id: i32)
    {
        this.id = id
    }
}

type Tag<T>
{
    id: i32
    data: T

    init(id: i32, data: T)
    {
        this.id = id
        this.data = data
    }

    fn Data() -> T
    {
        return data
    }
}

type Program
{
    static fn Main -> i32
    {
        var t0 = Tag(1)
        var t1 = Tag<i32>(2, 11)
        return t1.Data()
    }
}
