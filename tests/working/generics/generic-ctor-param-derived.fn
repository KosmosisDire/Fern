---
Description: Constructor params with nested generic-of-type-param resolve under instantiation
Expected: 1
---

type Node<T>
{
    value: T

    init(value: T)
    {
        this.value = value
    }
}

type Edge<T>
{
    from: Node<T>
    to: Node<T>

    init(from: Node<T>, to: Node<T>)
    {
        this.from = from
        this.to = to
    }
}

type Program
{
    static fn Main -> i32
    {
        var e = Edge<i32>(Node<i32>(1), Node<i32>(2))
        return e.from.value
    }
}
