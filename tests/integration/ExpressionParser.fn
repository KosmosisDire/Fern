-- Expected: 498.446807


ref type Token
{
    string value
    bool isNumber

    new(string v)
    {
        value = v
    }

    fn ToFloat() -> float
    {
        if (!isNumber)
        {
            Print("Error: Token is not a number.")
            return 0.0
        }
        PrintLn("Converting token to float: " .Concat(value))
        PrintLn(FloatToString(StringToFloat(value)))
        return StringToFloat(value)
    }
}

fn GetSpaces(int count) -> string
{
    var spaces = ""
    for (int i = 0; i < count; i = i + 1)
    {
        spaces = spaces.Concat("  ")
    }
    return spaces
}

ref type Expression
{
    float left
    Token operator
    Expression right

    new()
    {
    }

    fn ToString(int depth) -> string
    {
        if (right == null || operator == null || operator.value == null)
        {
            return GetSpaces(depth).Concat("Left: ").Concat(FloatToString(left))
        }

        var result = GetSpaces(depth).Concat("Left: ").Concat(FloatToString(left)).Concat("\n")
                        .Concat(GetSpaces(depth)).Concat("Operator: ").Concat(operator.value).Concat("\n")
                        .Concat(GetSpaces(depth)).Concat("Right: ").Concat("\n").Concat(GetSpaces(depth)).Concat("{\n")
                        .Concat(right.ToString(depth + 1)).Concat("\n")
                        .Concat(GetSpaces(depth))
                        .Concat("}")

        return result
    }

    fn Evaluate() -> float
    {
        if (operator == null || right == null)
        {
            return left
        }

        var rightValue = right.Evaluate()

        if (operator.value.data[0] == '+')
        {
            return left + rightValue
        }
        else if (operator.value.data[0] == '-')
        {
            return left - rightValue
        }
        else if (operator.value.data[0] == '*')
        {
            return left * rightValue
        }
        else if (operator.value.data[0] == '/')
        {
            return left / rightValue
        }
        else
        {
            PrintLn("Error: Unknown operator ".Concat(operator.value))
            return 0.0
        }
    }
}

type TokenList
{
    Token* tokens
    int count
    int capacity
    int tokenSize

    new()
    {
        tokenSize = 8
        capacity = 10
        tokens = (Token*)malloc(capacity * tokenSize)
        count = 0
    }

    fn Grow
    {
        capacity *= 2
        Token* newTokens = (Token*)malloc(capacity * tokenSize)
        memcpy(newTokens, tokens, count * tokenSize)
        free(tokens)
        tokens = newTokens
    }

    fn Add(Token t)
    {
        if (count >= capacity)
        {
            Grow()
        }
        tokens[count] = t
        count += 1
    }

    fn Get(int index)
    {
        return tokens[index]
    }

    fn Count
    {
        return count
    }

    fn Free
    {
        free(tokens)
    }

    fn ToString() -> string
    {
        var result = "["
        for (int i = 0; i < count; i += 1)
        {
            result = result.Concat(tokens[i].value)

            if (tokens[i].isNumber)
            {
                result = result.Concat("(num)")
            }
            else
            {
                result = result.Concat("(op)")
            }

            if (i < count - 1)
            {
                result = result.Concat(", ")
            }
        }
        result = result.Concat("]")
        return result
    }
}

fn IsDigit(char ch) -> bool
{
    return ch >= '0' && ch <= '9'
}

fn Main
{
    var input = "34 * 4.2 + 2 * 5.2301"
    var tokenList = new TokenList()

    for (i32 i = 0; i < input.Length(); i += 1)
    {
        var ch = input.data[i]
        var next = '\0'
        if (i + 1 < input.Length())
        {
            next = input.data[i + 1]
        }

        if (ch == ' ')
        {
            continue
        }
        
        if (IsDigit(ch))
        {
            var numStr = CharToString(ch)
            while (IsDigit(next) || next == '.')
            {
                i += 1
                ch = next
                numStr = numStr.Concat(CharToString(ch))
                if (i + 1 < input.Length())
                {
                    next = input.data[i + 1]
                }
                else
                {
                    break
                }
            }
            var numberToken = new Token(numStr)
            numberToken.isNumber = true
            tokenList.Add(numberToken)
            continue
        }
        
        var token = new Token(CharToString(ch))
        tokenList.Add(token)
    }

    PrintLn(tokenList.ToString())

    var root = new Expression()
    var expr = root
    var tokenIter = 0
    while (tokenIter < tokenList.Count())
    {
        var currentToken = tokenList.Get(tokenIter)
        if (currentToken.isNumber)
        {
            if (expr.operator == null)
            {
                -- No operator yet - this is the left side
                expr.left = currentToken.ToFloat()
            }
            else
            {
                -- Already have operator - build right subtree
                expr.right = new Expression()
                expr = expr.right
                expr.left = currentToken.ToFloat()
            }
        }
        else
        {
            PrintLn("Setting operator: ".Concat(currentToken.value))
            expr.operator = currentToken
        }

        tokenIter += 1
    }

    PrintLn("")
    PrintLn(root.ToString(0))

    var result = root.Evaluate()
    PrintLn("Result: ".Concat(FloatToString(result)))
    tokenList.Free()
    
    return result
}