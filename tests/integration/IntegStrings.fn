-- Expected: 12.0
fn Main
{
    var message = "Hello World!"
    var messages = ["Hello", "from", "Fern", "Language", "!"]
    
    for (var i = 0; i < 5; i = i + 1)
    {
        Print(message)
    }

    for (var j = 0; j < 5; j += 1)
    {
        Print(messages[j])
    }

    return (f32)message.Length()
}

