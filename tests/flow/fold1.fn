-- Constant Folding + Propagation Tests
-- Run and inspect FHIR output to verify correct folding behavior.
-- Comments describe what the FHIR SHOULD show.


---
SECTION 1: Basic propagation
---


type BasicProp
{
    -- x should be inlined: use(10)
    fn LiteralInt
    {
        var x = 10
        var y = x
    }

    -- x should be inlined: use(true)
    fn LiteralBool
    {
        var x = true
        var y = x
    }

    -- x should NOT be inlined (param is not constant)
    fn ParamNotConstant(val: i32)
    {
        var x = val
        var y = x
    }

    -- x should fold: 1+2 → 3, then y = 3
    fn ExprFoldsToConstant
    {
        var x = 1 + 2
        var y = x
    }

    init{}
}


---
SECTION 2: Reassignment
---


type ReassignProp
{
    -- x should be 20 at use point (reassigned)
    fn ReassignConstant
    {
        var x = 10
        x = 20
        var y = x
    }

    -- chain: x should be 30 at use
    fn ReassignChain
    {
        var x = 10
        x = 20
        x = 30
        var y = x
    }

    -- x should NOT be inlined after non-constant assignment
    fn ReassignNonConstant(val: i32)
    {
        var x = 10
        x = val
        var y = x
    }

    -- x should be inlined again after re-assigning to constant
    fn ReassignBackToConstant(val: i32)
    {
        var x = 10
        x = val
        x = 42
        var y = x
    }

    init{}
}


---
SECTION 3: If with unknown condition - invalidation
---


type IfUnknownInvalidation
{
    -- x modified in then only → unknown after if
    fn ModifiedInThen(cond: bool)
    {
        var x = 10
        if cond
        {
            x = 20
        }
        var y = x
    }

    -- x modified in else only → unknown after if
    fn ModifiedInElse(cond: bool)
    {
        var x = 10
        if cond
        {
            var z = 1
        }
        else
        {
            x = 20
        }
        var y = x
    }

    -- x modified in both branches → still unknown after if
    fn ModifiedInBoth(cond: bool)
    {
        var x = 10
        if cond
        {
            x = 20
        }
        else
        {
            x = 30
        }
        var y = x
    }

    -- x NOT modified in any branch → still unknown after if
    -- (conservative: we clear all constants on unknown condition)
    fn NotModifiedInIf(cond: bool)
    {
        var x = 10
        if cond
        {
            var z = 1
        }
        var y = x
    }

    -- x set before if, different var modified in if → x still unknown
    -- (conservative: clear all)
    fn OtherVarModified(cond: bool)
    {
        var x = 10
        var z = 5
        if cond
        {
            z = 20
        }
        var y = x
    }

    init{}
}


---
SECTION 4: If with constant true condition
---


type IfTruePropagation
{
    -- then definitely runs: x=20 should propagate out
    fn ThenPropagates
    {
        var x = 10
        if true
        {
            x = 20
        }
        var y = x
    }

    -- else does NOT run: x stays 10 (then modifications are truth)
    fn ElseIgnored
    {
        var x = 10
        if true
        {
            var z = 1
        }
        else
        {
            x = 99
        }
        var y = x
    }

    -- then sets x, else also sets x → only then matters
    fn ThenWinsOverElse
    {
        var x = 10
        if true
        {
            x = 20
        }
        else
        {
            x = 99
        }
        var y = x
    }

    init{}
}


---
SECTION 5: If with constant false condition
---


type IfFalsePropagation
{
    -- then does NOT run: x stays 10
    fn ThenIgnored
    {
        var x = 10
        if false
        {
            x = 99
        }
        var y = x
    }

    -- else definitely runs: x=20 propagates out
    fn ElsePropagates
    {
        var x = 10
        if false
        {
            var z = 1
        }
        else
        {
            x = 20
        }
        var y = x
    }

    -- no else branch: x stays 10
    fn NoElse
    {
        var x = 10
        if false
        {
            x = 99
        }
        var y = x
    }

    init{}
}


---
SECTION 6: While - invalidation
---


type WhileInvalidation
{
    -- x set before while, not modified in body → unknown after while
    -- (conservative: while clears everything)
    fn NotModifiedInWhile(cond: bool)
    {
        var x = 10
        while cond
        {
            var z = 1
        }
        var y = x
    }

    -- x modified in while body → unknown after while
    fn ModifiedInWhile(cond: bool)
    {
        var x = 10
        while cond
        {
            x = 20
        }
        var y = x
    }

    -- constants should NOT propagate INTO while body
    -- (x should NOT be inlined inside the body)
    fn NoPropagationIntoBody(cond: bool)
    {
        var x = 10
        while cond
        {
            var y = x
            x = 20
        }
    }

    -- while(true): same rules, body constants cleared after
    fn WhileTrueClearsAfter
    {
        var x = 10
        while true
        {
            x = 20
            return
        }
        var y = x
    }

    init{}
}


---
SECTION 7: Nested control flow
---


type NestedInvalidation
{
    -- if inside if: inner unknown if invalidates, outer sees unknown
    fn IfInsideIf(a: bool, b: bool)
    {
        var x = 10
        if a
        {
            if b
            {
                x = 20
            }
        }
        var y = x
    }

    -- while inside if(true): while still clears
    fn WhileInsideConstIf
    {
        var x = 10
        if true
        {
            while true
            {
                x = 20
                return
            }
        }
        var y = x
    }

    -- if inside while: everything unknown
    fn IfInsideWhile(a: bool, b: bool)
    {
        var x = 10
        while a
        {
            if b
            {
                x = 20
            }
        }
        var y = x
    }

    -- sequential ifs: first invalidates, second can't see constant
    fn SequentialIfs(a: bool, b: bool)
    {
        var x = 10
        if a
        {
            x = 20
        }
        -- x is unknown here
        if b
        {
            var z = x
        }
        var y = x
    }

    -- constant if(true) then while inside: while clears,
    -- but if(true) propagates the post-while state
    fn ConstIfThenWhile(cond: bool)
    {
        var x = 10
        if true
        {
            while cond
            {
                x = 20
            }
        }
        var y = x
    }

    init{}
}


---
SECTION 8: Multiple variables
---


type MultiVar
{
    -- only the modified variable should be affected
    -- after unknown if: both x and z are unknown (conservative clear)
    fn IndependentVars(cond: bool)
    {
        var x = 10
        var z = 20
        if cond
        {
            x = 30
        }
        var a = x
        var b = z
    }

    -- propagation through arithmetic with two vars
    fn TwoVarArithmetic
    {
        var x = 10
        var y = 20
        var z = x + y
    }

    init{}
}
