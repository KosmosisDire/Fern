-- Expected: 12.0
type Counter
{
    f32 value

    new(f32 initial)
    {
        value = initial
    }

    fn Increment
    {
        value += 1.0
    }

    fn GetValue -> f32
    {
        return value
    }
}

fn Main
{
    var counter = new Counter(10.0)
    counter.Increment()
    counter.Increment()
    return counter.GetValue()
}
