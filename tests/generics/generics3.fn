---
Generics with initializer lists.
Tests that initializer lists work correctly with generic types.
---

type Point<T>
{
    x: T
    y: T

    init{}
}

type Bounds<T>
{
    min: Point<T>
    max: Point<T>

    init{}
}

type Program
{
    fn Main()
    {
        var b = Bounds<f32>
        {
            min: Point<f32> { x: 1.0, y: 2.0 }
            max: Point<f32> { x: 3.0, y: 4.0 }
        }
    }
}
