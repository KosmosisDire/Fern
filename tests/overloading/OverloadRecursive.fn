-- Expected: 233.0
-- Test recursive functions with overloading

fn Fib(i32 n) -> i32
{
    if n <= 1
    {
        return n
    }
    return Fib(n - 1) + Fib(n - 2)
}

fn Fib(i32 n, i32 a, i32 b) -> i32
{
    -- Tail-recursive style with accumulators
    if n == 0
    {
        return a
    }
    return Fib(n - 1, b, a + b)
}

fn Factorial(i32 n) -> i32
{
    if n <= 1
    {
        return 1
    }
    return n * Factorial(n - 1)
}

fn Factorial(i32 n, i32 acc) -> i32
{
    -- Tail-recursive style with accumulator
    if n <= 1
    {
        return acc
    }
    return Factorial(n - 1, n * acc)
}

fn Power(f32 base, i32 exp) -> f32
{
    if exp == 0
    {
        return 1.0
    }
    if exp == 1
    {
        return base
    }
    return base * Power(base, exp - 1)
}

fn Power(f32 base, i32 exp, f32 acc) -> f32
{
    -- With accumulator
    if exp == 0
    {
        return acc
    }
    return Power(base, exp - 1, acc * base)
}

fn Main
{
    -- Fib(10) using simple recursion = 55
    var f1 = Fib(10)

    -- Fib(10, 0, 1) using tail recursion = 55
    var f2 = Fib(10, 0, 1)

    -- Factorial(5) = 120
    var fact1 = Factorial(5)

    -- Factorial(5, 1) = 120
    var fact2 = Factorial(5, 1)

    -- Power(2.0, 4) = 16.0
    var p1 = Power(2.0, 4)

    -- Power(2.0, 4, 1.0) = 16.0
    var p2 = Power(2.0, 4, 1.0)

    -- f1=55, f2=55, fact1=120, fact2=120, p1=16, p2=16
    -- Using: f1 + f2 - fact1 + fact2 + p1 + p2 - 49 = 55 + 55 - 120 + 120 + 16 + 16 + 91 = 233
    return f1 + f2 - fact1 + fact2 + p1 + p2 + 91.0
}
