-- Expected: 500.0
-- Test nested function calls with overloading resolution

fn Inner(i32 x) -> i32
{
    return x * 2
}

fn Inner(f32 x) -> f32
{
    return x * 3.0
}

fn Middle(i32 x) -> i32
{
    return Inner(x) + 10
}

fn Middle(f32 x) -> f32
{
    return Inner(x) + 20.0
}

fn Outer(i32 x) -> f32
{
    return Middle(x) + 0.0
}

fn Outer(f32 x) -> f32
{
    return Middle(x)
}

-- Overloads that call different overloads based on conversion
fn Compute(i32 a, i32 b) -> f32
{
    return Outer(a) + Outer(b)
}

fn Compute(f32 a, f32 b) -> f32
{
    return Outer(a) + Outer(b) + 100.0
}

fn Compute(i32 a, f32 b) -> f32
{
    return Outer(a) + Outer(b) + 50.0
}

fn Main
{
    -- Outer(5) = Middle(5) = Inner(5) + 10 = 10 + 10 = 20
    var o1 = Outer(5)      -- 20

    -- Outer(5.0) = Middle(5.0) = Inner(5.0) + 20 = 15 + 20 = 35
    var o2 = Outer(5.0)    -- 35

    -- Compute(2, 3) = Outer(2) + Outer(3) = (4+10) + (6+10) = 14 + 16 = 30
    var c1 = Compute(2, 3) -- 30

    -- Compute(2.0, 3.0) = Outer(2.0) + Outer(3.0) + 100
    --   = (6+20) + (9+20) + 100 = 26 + 29 + 100 = 155
    var c2 = Compute(2.0, 3.0) -- 155

    -- Compute(2, 3.0) = Outer(2) + Outer(3.0) + 50
    --   = (4+10) + (9+20) + 50 = 14 + 29 + 50 = 93
    var c3 = Compute(2, 3.0)   -- 93

    -- Expected: 20 + 35 + 30 + 155 + 93 + 167 = 500
    return o1 + o2 + c1 + c2 + c3 + 167.0
}
