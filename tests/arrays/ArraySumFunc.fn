-- Expected: 39.0

fn Sum(i32[] arr, i32 length) -> i32
{
    var total = 0
    for (var i = 0; i < length; i = i + 1)
    {
        total = total + arr[i]
    }
    return total
}

fn Main
{
    var array1 = [1, 2, 3, 4, 5]
    var array2 = array1
    array2[0] = 10

    var sum1 = Sum(array1, 5)
    var sum2 = Sum(array2, 5)

    var str1 = IntToString(sum1)
    var str2 = IntToString(sum2)

    Print(str1)
    Print(str2)

    return (f32)(sum1 + sum2)
}
  
